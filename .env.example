# Postgres connection string (Neon, Fly Postgres, or any Postgres). Required.
DATABASE_URL=

# 32-byte key, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENC_KEY=

# Shared secret checked on the /api/cron/sync manual-trigger endpoint.
CRON_SECRET=

# Secret used to sign the internal login session JWT.
SESSION_SECRET=

# mock | live -- controls which ELD adapters (leader/factor/nexus) are used.
ELD_MODE=mock

# Base URL of the deployed app (used by the /api/cron/sync dispatcher to call itself).
APP_URL=http://localhost:3000

# Minutes between automatic sync runs (src/instrumentation.ts). Default 15.
SYNC_INTERVAL_MINUTES=15

# Set to "true" to disable the in-process sync loop (e.g. in short-lived local dev runs).
DISABLE_SYNC_LOOP=false
