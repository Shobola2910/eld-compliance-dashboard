# Postgres connection string (Neon / Vercel Postgres). Required.
DATABASE_URL=

# 32-byte key, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENC_KEY=

# Shared secret checked on /api/cron/sync requests (also set as a GitHub Actions repo secret).
CRON_SECRET=

# mock | live -- default mode for any provider without its own override below.
ELD_MODE=mock

# Per-provider override, takes precedence over ELD_MODE above. Lets one provider go live
# while the others stay on mock data until their real adapters are finished.
# ELD_MODE_LEADER=live
# ELD_MODE_FACTOR=live
# ELD_MODE_NEXUS=live

# Base URL of the deployed app (used by the cron dispatcher to call itself).
APP_URL=http://localhost:3000
