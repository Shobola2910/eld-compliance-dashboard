# Postgres connection string (Neon / Vercel Postgres). Required.
DATABASE_URL=

# 32-byte key, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENC_KEY=

# Shared secret checked on /api/cron/sync requests (also set as a GitHub Actions repo secret).
CRON_SECRET=

# Secret used to sign the internal login session JWT.
SESSION_SECRET=

# mock | live -- controls which ELD adapters (leader/factor/nexus) are used.
ELD_MODE=mock

# Base URL of the deployed app (used by the cron dispatcher to call itself).
APP_URL=http://localhost:3000
